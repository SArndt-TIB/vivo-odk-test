AnnotationAssertion(rdfs:comment <http://www.w3.org/2006/vcard/ns#Language> "To specify the language(s) that may be used for contacting the entity associated with the vCard.")
AnnotationAssertion(rdfs:label <http://www.w3.org/2006/vcard/ns#Language> "Language"@en)
EquivalentClasses(<http://www.w3.org/2006/vcard/ns#Language> ObjectIntersectionOf(DataAllValuesFrom(<http://www.w3.org/2006/vcard/ns#language> xsd:string) DataExactCardinality(1 <http://www.w3.org/2006/vcard/ns#language>)))
