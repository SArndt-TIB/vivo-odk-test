#   Object Properties
############################

# Object Property: <http://www.w3.org/2008/05/skos#broadMatch> (broader match)

AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#broadMatch> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#broadMatch> "broader match"@en)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#broadMatch> <http://www.w3.org/2008/05/skos#broader>)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#broadMatch> <http://www.w3.org/2008/05/skos#mappingRelation>)
InverseObjectProperties(<http://www.w3.org/2008/05/skos#broadMatch> <http://www.w3.org/2008/05/skos#narrowMatch>)

# Object Property: <http://www.w3.org/2008/05/skos#broader> (has broader)

AnnotationAssertion(rdfs:comment <http://www.w3.org/2008/05/skos#broader> "Broader concepts are typically rendered as parents in a concept hierarchy (tree)."@en)
AnnotationAssertion(rdfs:comment <http://www.w3.org/2008/05/skos#broader> "By convention, skos:broader is only used to assert an immediate (i.e. direct) hierarchical link between two conceptual resources."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#broader> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#broader> "has broader"@en)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#broader> <http://www.w3.org/2008/05/skos#broaderTransitive>)
InverseObjectProperties(<http://www.w3.org/2008/05/skos#broader> <http://www.w3.org/2008/05/skos#narrower>)

# Object Property: <http://www.w3.org/2008/05/skos#broaderTransitive> (broader transitive)

AnnotationAssertion(rdfs:comment <http://www.w3.org/2008/05/skos#broaderTransitive> "By convention, skos:broaderTransitive is not used to make assertions. Rather, the properties can be used to draw inferences about the transitive closure of the hierarchical relation, which is useful e.g. when implementing a simple query expansion algorithm in a search application."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#broaderTransitive> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#broaderTransitive> "broader transitive"@en)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#broaderTransitive> <http://www.w3.org/2008/05/skos#semanticRelation>)
InverseObjectProperties(<http://www.w3.org/2008/05/skos#broaderTransitive> <http://www.w3.org/2008/05/skos#narrowerTransitive>)
TransitiveObjectProperty(<http://www.w3.org/2008/05/skos#broaderTransitive>)

# Object Property: <http://www.w3.org/2008/05/skos#changeNote> (change note)

AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#changeNote> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#changeNote> "change note"@en)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#changeNote> <http://www.w3.org/2008/05/skos#note>)

# Object Property: <http://www.w3.org/2008/05/skos#closeMatch> (exact match)

AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#closeMatch> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#closeMatch> "exact match"@en)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#closeMatch> <http://www.w3.org/2008/05/skos#mappingRelation>)
SymmetricObjectProperty(<http://www.w3.org/2008/05/skos#closeMatch>)

# Object Property: <http://www.w3.org/2008/05/skos#definition> (<http://www.w3.org/2008/05/skos#definition>)

SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#definition> <http://www.w3.org/2008/05/skos#note>)

# Object Property: <http://www.w3.org/2008/05/skos#editorialNote> (editorial note)

AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#editorialNote> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#editorialNote> "editorial note"@en)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#editorialNote> <http://www.w3.org/2008/05/skos#note>)

# Object Property: <http://www.w3.org/2008/05/skos#exactMatch> (exact match)

AnnotationAssertion(rdfs:comment <http://www.w3.org/2008/05/skos#exactMatch> "skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#exactMatch> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#exactMatch> "exact match"@en)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#exactMatch> <http://www.w3.org/2008/05/skos#closeMatch>)
SymmetricObjectProperty(<http://www.w3.org/2008/05/skos#exactMatch>)
TransitiveObjectProperty(<http://www.w3.org/2008/05/skos#exactMatch>)

# Object Property: <http://www.w3.org/2008/05/skos#example> (example)

AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#example> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#example> "example"@en)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#example> <http://www.w3.org/2008/05/skos#note>)

# Object Property: <http://www.w3.org/2008/05/skos#hasTopConcept> (has top concept)

AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#hasTopConcept> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#hasTopConcept> "has top concept"@en)
InverseObjectProperties(<http://www.w3.org/2008/05/skos#hasTopConcept> <http://www.w3.org/2008/05/skos#topConceptOf>)
ObjectPropertyDomain(<http://www.w3.org/2008/05/skos#hasTopConcept> <http://www.w3.org/2008/05/skos#ConceptScheme>)
ObjectPropertyRange(<http://www.w3.org/2008/05/skos#hasTopConcept> <http://www.w3.org/2008/05/skos#Concept>)

# Object Property: <http://www.w3.org/2008/05/skos#historyNote> (history note)

AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#historyNote> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#historyNote> "history note"@en)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#historyNote> <http://www.w3.org/2008/05/skos#note>)

# Object Property: <http://www.w3.org/2008/05/skos#inScheme> (in scheme)

AnnotationAssertion(rdfs:comment <http://www.w3.org/2008/05/skos#inScheme> "A concept may be a member of more than one concept scheme."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#inScheme> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#inScheme> "in scheme"@en)
ObjectPropertyRange(<http://www.w3.org/2008/05/skos#inScheme> <http://www.w3.org/2008/05/skos#ConceptScheme>)

# Object Property: <http://www.w3.org/2008/05/skos#mappingRelation> (mapping relation)

AnnotationAssertion(rdfs:comment <http://www.w3.org/2008/05/skos#mappingRelation> "These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#mappingRelation> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#mappingRelation> "mapping relation"@en)
ObjectPropertyDomain(<http://www.w3.org/2008/05/skos#mappingRelation> <http://www.w3.org/2008/05/skos#Concept>)
ObjectPropertyRange(<http://www.w3.org/2008/05/skos#mappingRelation> <http://www.w3.org/2008/05/skos#Concept>)

# Object Property: <http://www.w3.org/2008/05/skos#member> (member)

AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#member> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#member> "member"@en)
ObjectPropertyDomain(<http://www.w3.org/2008/05/skos#member> <http://www.w3.org/2008/05/skos#Collection>)

# Object Property: <http://www.w3.org/2008/05/skos#memberList> (member list)

AnnotationAssertion(rdfs:comment <http://www.w3.org/2008/05/skos#memberList> "For any resource, every item in the list given as the value of the skos:memberList property is also a value of the skos:member property."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#memberList> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#memberList> "member list"@en)
FunctionalObjectProperty(<http://www.w3.org/2008/05/skos#memberList>)
ObjectPropertyDomain(<http://www.w3.org/2008/05/skos#memberList> <http://www.w3.org/2008/05/skos#OrderedCollection>)
ObjectPropertyRange(<http://www.w3.org/2008/05/skos#memberList> rdf:List)

# Object Property: <http://www.w3.org/2008/05/skos#narrowMatch> (narrower match)

AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#narrowMatch> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#narrowMatch> "narrower match"@en)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#narrowMatch> <http://www.w3.org/2008/05/skos#mappingRelation>)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#narrowMatch> <http://www.w3.org/2008/05/skos#narrower>)

# Object Property: <http://www.w3.org/2008/05/skos#narrower> (has narrower)

AnnotationAssertion(rdfs:comment <http://www.w3.org/2008/05/skos#narrower> "By convention, skos:broader is only used to assert an immediate (i.e. direct) hierarchical link between two conceptual resources."@en)
AnnotationAssertion(rdfs:comment <http://www.w3.org/2008/05/skos#narrower> "Narrower concepts are typically rendered as children in a concept hierarchy (tree)."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#narrower> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#narrower> "has narrower"@en)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#narrower> <http://www.w3.org/2008/05/skos#narrowerTransitive>)

# Object Property: <http://www.w3.org/2008/05/skos#narrowerTransitive> (narrower transitive)

AnnotationAssertion(rdfs:comment <http://www.w3.org/2008/05/skos#narrowerTransitive> "By convention, skos:narrowerTransitive is not used to make assertions. Rather, the properties can be used to draw inferences about the transitive closure of the hierarchical relation, which is useful e.g. when implementing a simple query expansion algorithm in a search application."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#narrowerTransitive> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#narrowerTransitive> "narrower transitive"@en)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#narrowerTransitive> <http://www.w3.org/2008/05/skos#semanticRelation>)
TransitiveObjectProperty(<http://www.w3.org/2008/05/skos#narrowerTransitive>)

# Object Property: <http://www.w3.org/2008/05/skos#note> (note)

AnnotationAssertion(rdfs:comment <http://www.w3.org/2008/05/skos#note> "This property may be used directly, or as a super-property for more specific note types."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#note> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#note> "note"@en)

# Object Property: <http://www.w3.org/2008/05/skos#related> (related to)

AnnotationAssertion(rdfs:comment <http://www.w3.org/2008/05/skos#related> "skos:related is disjoint with skos:broaderTransitive"@en)
AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#related> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#related> "related to"@en)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#related> <http://www.w3.org/2008/05/skos#semanticRelation>)
SymmetricObjectProperty(<http://www.w3.org/2008/05/skos#related>)

# Object Property: <http://www.w3.org/2008/05/skos#relatedMatch> (related match)

AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#relatedMatch> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#relatedMatch> "related match"@en)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#relatedMatch> <http://www.w3.org/2008/05/skos#mappingRelation>)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#relatedMatch> <http://www.w3.org/2008/05/skos#related>)
SymmetricObjectProperty(<http://www.w3.org/2008/05/skos#relatedMatch>)

# Object Property: <http://www.w3.org/2008/05/skos#scopeNote> (scope note)

AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#scopeNote> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#scopeNote> "scope note"@en)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#scopeNote> <http://www.w3.org/2008/05/skos#note>)

# Object Property: <http://www.w3.org/2008/05/skos#semanticRelation> (semantic relation)

AnnotationAssertion(rdfs:comment <http://www.w3.org/2008/05/skos#semanticRelation> "This property should not be used directly, but as a super-property for all properties denoting a relationship of meaning between concepts."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#semanticRelation> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#semanticRelation> "semantic relation"@en)
ObjectPropertyDomain(<http://www.w3.org/2008/05/skos#semanticRelation> <http://www.w3.org/2008/05/skos#Concept>)
ObjectPropertyRange(<http://www.w3.org/2008/05/skos#semanticRelation> <http://www.w3.org/2008/05/skos#Concept>)

# Object Property: <http://www.w3.org/2008/05/skos#topConceptOf> (top concept in scheme)

AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2008/05/skos#topConceptOf> <http://www.w3.org/2008/05/skos>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2008/05/skos#topConceptOf> "top concept in scheme"@en)
SubObjectPropertyOf(<http://www.w3.org/2008/05/skos#topConceptOf> <http://www.w3.org/2008/05/skos#inScheme>)
