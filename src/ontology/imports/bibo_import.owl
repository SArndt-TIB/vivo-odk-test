AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Report> "Report"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Report> "stable")
