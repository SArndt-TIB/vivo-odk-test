############################
#   Object Properties
############################

# Object Property: <http://purl.org/NET/c4dm/event.owl#product> (<http://purl.org/NET/c4dm/event.owl#product>)

AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#scopeNote> <http://purl.org/NET/c4dm/event.owl#product> "Used to link an event such as a conference to an outcome (a product) of that event, for example, an article, a proceeding, etc."@en)

# Object Property: <http://purl.org/dc/terms/contributor> (<http://purl.org/dc/terms/contributor>)

AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#scopeNote> <http://purl.org/dc/terms/contributor> "Used to link a bibliographic item to one of its contributor: can be an author, an editor, a publisher, etc."@en)

# Object Property: <http://purl.org/dc/terms/isReferencedBy> (<http://purl.org/dc/terms/isReferencedBy>)

AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#scopeNote> <http://purl.org/dc/terms/isReferencedBy> "Used to relate a reference citation to a bibliographic resource."@en)

# Object Property: <http://purl.org/dc/terms/publisher> (<http://purl.org/dc/terms/publisher>)

AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#scopeNote> <http://purl.org/dc/terms/publisher> "Used to link a bibliographic item to its publisher."@en)

# Object Property: <http://purl.org/ontology/bibo/affirmedBy> (<http://purl.org/ontology/bibo/affirmedBy>)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/affirmedBy> "A legal decision that affirms a ruling."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/affirmedBy> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
SubObjectPropertyOf(<http://purl.org/ontology/bibo/affirmedBy> <http://purl.org/ontology/bibo/subsequentLegalDecision>)
ObjectPropertyDomain(<http://purl.org/ontology/bibo/affirmedBy> <http://purl.org/ontology/bibo/LegalDecision>)
ObjectPropertyRange(<http://purl.org/ontology/bibo/affirmedBy> <http://purl.org/ontology/bibo/LegalDecision>)

# Object Property: <http://purl.org/ontology/bibo/annotates> (annotates)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/annotates> "Critical or explanatory note for a Document."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/annotates> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/annotates> "annotates"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/annotates> "stable")
SubObjectPropertyOf(<http://purl.org/ontology/bibo/annotates> <http://purl.org/dc/terms/relation>)
ObjectPropertyDomain(<http://purl.org/ontology/bibo/annotates> <http://purl.org/ontology/bibo/Note>)
ObjectPropertyRange(<http://purl.org/ontology/bibo/annotates> rdfs:Resource)

# Object Property: <http://purl.org/ontology/bibo/citedBy> (cited by)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/citedBy> "Relates a document to another document that cites the
first document."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/citedBy> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/citedBy> "cited by"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/citedBy> "unstable")
InverseObjectProperties(<http://purl.org/ontology/bibo/citedBy> <http://purl.org/ontology/bibo/cites>)
ObjectPropertyDomain(<http://purl.org/ontology/bibo/citedBy> <http://purl.org/ontology/bibo/Document>)
ObjectPropertyRange(<http://purl.org/ontology/bibo/citedBy> <http://purl.org/ontology/bibo/Document>)

# Object Property: <http://purl.org/ontology/bibo/cites> (cites)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/cites> "Relates a document to another document that is cited
by the first document as reference, comment, review, quotation or for
another purpose."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/cites> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/cites> "cites"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/cites> "unstable")
SubObjectPropertyOf(<http://purl.org/ontology/bibo/cites> <http://purl.org/dc/terms/references>)
ObjectPropertyDomain(<http://purl.org/ontology/bibo/cites> <http://purl.org/ontology/bibo/Document>)
ObjectPropertyRange(<http://purl.org/ontology/bibo/cites> <http://purl.org/ontology/bibo/Document>)

# Object Property: <http://purl.org/ontology/bibo/court> (court)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/court> "A court associated with a legal document; for example, that which issues a decision."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/court> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/court> "court"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/court> "unstable")
ObjectPropertyDomain(<http://purl.org/ontology/bibo/court> <http://purl.org/ontology/bibo/LegalDocument>)
ObjectPropertyRange(<http://purl.org/ontology/bibo/court> <http://xmlns.com/foaf/0.1/Organization>)

# Object Property: <http://purl.org/ontology/bibo/degree> (degree)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/degree> "The thesis degree."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/degree> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/degree> "degree"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/degree> "unstable")
ObjectPropertyDomain(<http://purl.org/ontology/bibo/degree> <http://purl.org/ontology/bibo/Thesis>)
ObjectPropertyRange(<http://purl.org/ontology/bibo/degree> <http://purl.org/ontology/bibo/ThesisDegree>)

# Object Property: <http://purl.org/ontology/bibo/director> (director)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/director> "A Film director."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/director> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/director> "director")
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/director> "stable")
SubObjectPropertyOf(<http://purl.org/ontology/bibo/director> <http://purl.org/dc/terms/contributor>)
ObjectPropertyDomain(<http://purl.org/ontology/bibo/director> <http://purl.org/ontology/bibo/AudioVisualDocument>)
ObjectPropertyRange(<http://purl.org/ontology/bibo/director> <http://xmlns.com/foaf/0.1/Agent>)

# Object Property: <http://purl.org/ontology/bibo/distributor> (distributor)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/distributor> "Distributor of a document or a collection of documents."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/distributor> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/distributor> "distributor"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/distributor> "stable")
ObjectPropertyDomain(<http://purl.org/ontology/bibo/distributor> ObjectUnionOf(<http://purl.org/ontology/bibo/Collection> <http://purl.org/ontology/bibo/Document>))
ObjectPropertyRange(<http://purl.org/ontology/bibo/distributor> <http://xmlns.com/foaf/0.1/Agent>)

# Object Property: <http://purl.org/ontology/bibo/interviewee> (interviewee)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/interviewee> "An agent that is interviewed by another agent."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/interviewee> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/interviewee> "interviewee")
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/interviewee> "stable")
SubObjectPropertyOf(<http://purl.org/ontology/bibo/interviewee> <http://purl.org/dc/terms/contributor>)
ObjectPropertyDomain(<http://purl.org/ontology/bibo/interviewee> <http://xmlns.com/foaf/0.1/Agent>)
ObjectPropertyRange(<http://purl.org/ontology/bibo/interviewee> <http://xmlns.com/foaf/0.1/Agent>)

# Object Property: <http://purl.org/ontology/bibo/interviewer> (interviewer)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/interviewer> "An agent that interview another agent."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/interviewer> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/interviewer> "interviewer")
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/interviewer> "stable")
SubObjectPropertyOf(<http://purl.org/ontology/bibo/interviewer> <http://purl.org/dc/terms/contributor>)
ObjectPropertyDomain(<http://purl.org/ontology/bibo/interviewer> <http://xmlns.com/foaf/0.1/Agent>)
ObjectPropertyRange(<http://purl.org/ontology/bibo/interviewer> <http://xmlns.com/foaf/0.1/Agent>)

# Object Property: <http://purl.org/ontology/bibo/issuer> (issuer)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/issuer> "An entity responsible for issuing often informally published documents such as press releases, reports, etc.")
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/issuer> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/issuer> "issuer")
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/issuer> "unstable")
SubObjectPropertyOf(<http://purl.org/ontology/bibo/issuer> <http://purl.org/dc/terms/publisher>)
ObjectPropertyDomain(<http://purl.org/ontology/bibo/issuer> ObjectUnionOf(<http://purl.org/ontology/bibo/Collection> <http://purl.org/ontology/bibo/Document>))
ObjectPropertyRange(<http://purl.org/ontology/bibo/issuer> <http://xmlns.com/foaf/0.1/Agent>)

# Object Property: <http://purl.org/ontology/bibo/performer> (performer)

AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/performer> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/performer> "performer")
