AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Standard> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Standard> "Standard"@en)
