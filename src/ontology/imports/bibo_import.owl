AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Statute> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Statute> "Statute"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Statute> "stable")
