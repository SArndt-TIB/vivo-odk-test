SubClassOf(<http://purl.org/ontology/bibo/Slideshow> ObjectAllValuesFrom(<http://purl.org/dc/terms/hasPart> <http://purl.org/ontology/bibo/Slide>))

# Class: <http://purl.org/ontology/bibo/Specification> (Specification)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/Specification> "A document describing a specification."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Specification> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Specification> "Specification"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Specification> "testing")
