AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Patent> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Patent> "Patent"@en)
