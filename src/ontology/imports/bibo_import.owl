AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Slide> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Slide> "Slide"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Slide> "unstable")
