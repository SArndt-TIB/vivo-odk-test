AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/pageStart> "page start"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/pageStart> "stable")
SubDataPropertyOf(<http://purl.org/ontology/bibo/pageStart> <http://purl.org/ontology/bibo/locator>)
DataPropertyDomain(<http://purl.org/ontology/bibo/pageStart> <http://purl.org/ontology/bibo/Document>)

# Data Property: <http://purl.org/ontology/bibo/pmid> (<http://purl.org/ontology/bibo/pmid>)

SubDataPropertyOf(<http://purl.org/ontology/bibo/pmid> <http://purl.org/ontology/bibo/identifier>)
DataPropertyDomain(<http://purl.org/ontology/bibo/pmid> ObjectUnionOf(<http://purl.org/ontology/bibo/Collection> <http://purl.org/ontology/bibo/Document>))

# Data Property: <http://purl.org/ontology/bibo/prefixName> (prefix name)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/prefixName> "The prefix of a name"@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/prefixName> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/prefixName> "prefix name"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/prefixName> "stable")
DataPropertyDomain(<http://purl.org/ontology/bibo/prefixName> <http://xmlns.com/foaf/0.1/Agent>)

# Data Property: <http://purl.org/ontology/bibo/section> (section)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/section> "A section number"@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/section> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/section> "section"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/section> "unstable")
SubDataPropertyOf(<http://purl.org/ontology/bibo/section> <http://purl.org/ontology/bibo/locator>)
DataPropertyDomain(<http://purl.org/ontology/bibo/section> <http://purl.org/ontology/bibo/Document>)

# Data Property: <http://purl.org/ontology/bibo/shortDescription> (<http://purl.org/ontology/bibo/shortDescription>)

DataPropertyDomain(<http://purl.org/ontology/bibo/shortDescription> <http://purl.org/ontology/bibo/Document>)

# Data Property: <http://purl.org/ontology/bibo/sici> (<http://purl.org/ontology/bibo/sici>)

SubDataPropertyOf(<http://purl.org/ontology/bibo/sici> <http://purl.org/ontology/bibo/identifier>)
DataPropertyDomain(<http://purl.org/ontology/bibo/sici> ObjectUnionOf(<http://purl.org/ontology/bibo/Collection> <http://purl.org/ontology/bibo/Document>))

# Data Property: <http://purl.org/ontology/bibo/upc> (<http://purl.org/ontology/bibo/upc>)

SubDataPropertyOf(<http://purl.org/ontology/bibo/upc> <http://purl.org/ontology/bibo/identifier>)
DataPropertyDomain(<http://purl.org/ontology/bibo/upc> ObjectUnionOf(<http://purl.org/ontology/bibo/Collection> <http://purl.org/ontology/bibo/Document>))

# Data Property: <http://purl.org/ontology/bibo/uri> (uri)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/uri> "Universal Resource Identifier of a document"@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/uri> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/uri> "uri"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/uri> "stable")
SubDataPropertyOf(<http://purl.org/ontology/bibo/uri> <http://purl.org/ontology/bibo/identifier>)
DataPropertyDomain(<http://purl.org/ontology/bibo/uri> ObjectUnionOf(<http://purl.org/ontology/bibo/Collection> <http://purl.org/ontology/bibo/Document>))

# Data Property: <http://purl.org/ontology/bibo/volume> (volume)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/volume> "A volume number"@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/volume> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/volume> "volume"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/volume> "stable")
SubDataPropertyOf(<http://purl.org/ontology/bibo/volume> <http://purl.org/ontology/bibo/locator>)
DataPropertyDomain(<http://purl.org/ontology/bibo/volume> <http://purl.org/ontology/bibo/Document>)



############################
#   Classes
############################

# Class: <http://purl.org/NET/c4dm/event.owl#Event> (<http://purl.org/NET/c4dm/event.owl#Event>)

AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#scopeNote> <http://purl.org/NET/c4dm/event.owl#Event> "Used to describe bibliographic related events such as conferences, hearing, etc."@en)

# Class: <http://purl.org/dc/terms/Agent> (<http://purl.org/dc/terms/Agent>)

EquivalentClasses(<http://purl.org/dc/terms/Agent> <http://xmlns.com/foaf/0.1/Agent>)

# Class: <http://purl.org/ontology/bibo/AcademicArticle> (Academic Article)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/AcademicArticle> "A scholarly academic article, typically published in a journal."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/AcademicArticle> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/AcademicArticle> "Academic Article"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/AcademicArticle> "stable")
SubClassOf(<http://purl.org/ontology/bibo/AcademicArticle> <http://purl.org/ontology/bibo/Article>)

# Class: <http://purl.org/ontology/bibo/Article> (Article)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/Article> "A written composition in prose, usually nonfiction, on a specific topic, forming an independent part of a book or other publication, as a newspaper or magazine."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Article> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Article> "Article"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Article> "stable")
SubClassOf(<http://purl.org/ontology/bibo/Article> <http://purl.org/ontology/bibo/Document>)

# Class: <http://purl.org/ontology/bibo/AudioDocument> (audio document)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/AudioDocument> "An audio document; aka record."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/AudioDocument> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/AudioDocument> "audio document"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/AudioDocument> "stable")
SubClassOf(<http://purl.org/ontology/bibo/AudioDocument> <http://purl.org/ontology/bibo/Document>)

# Class: <http://purl.org/ontology/bibo/AudioVisualDocument> (audio-visual document)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/AudioVisualDocument> "An audio-visual document; film, video, and so forth."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/AudioVisualDocument> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/AudioVisualDocument> "audio-visual document"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/AudioVisualDocument> "stable")
SubClassOf(<http://purl.org/ontology/bibo/AudioVisualDocument> <http://purl.org/ontology/bibo/Document>)

# Class: <http://purl.org/ontology/bibo/Bill> (Bill)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/Bill> "Draft legislation presented for discussion to a legal body."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Bill> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Bill> "Bill"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Bill> "stable")
SubClassOf(<http://purl.org/ontology/bibo/Bill> <http://purl.org/ontology/bibo/Legislation>)

# Class: <http://purl.org/ontology/bibo/Book> (Book)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/Book> "A written or printed work of fiction or nonfiction, usually on sheets of paper fastened or bound together within covers."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Book> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Book> "Book"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Book> "stable")
SubClassOf(<http://purl.org/ontology/bibo/Book> <http://purl.org/ontology/bibo/Document>)

# Class: <http://purl.org/ontology/bibo/BookSection> (Book Section)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/BookSection> "A section of a book."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/BookSection> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/BookSection> "Book Section"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/BookSection> "unstable")
SubClassOf(<http://purl.org/ontology/bibo/BookSection> <http://purl.org/ontology/bibo/DocumentPart>)

# Class: <http://purl.org/ontology/bibo/Brief> (Brief)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/Brief> "A written argument submitted to a court."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Brief> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Brief> "Brief"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Brief> "unstable")
SubClassOf(<http://purl.org/ontology/bibo/Brief> <http://purl.org/ontology/bibo/LegalCaseDocument>)

# Class: <http://purl.org/ontology/bibo/Chapter> (Chapter)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/Chapter> "A chapter of a book."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Chapter> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Chapter> "Chapter"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Chapter> "unstable")
SubClassOf(<http://purl.org/ontology/bibo/Chapter> <http://purl.org/ontology/bibo/BookSection>)

# Class: <http://purl.org/ontology/bibo/Code> (Code)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/Code> "A collection of statutes."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Code> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Code> "Code"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Code> "stable")
SubClassOf(<http://purl.org/ontology/bibo/Code> <http://purl.org/ontology/bibo/Periodical>)
SubClassOf(<http://purl.org/ontology/bibo/Code> ObjectAllValuesFrom(<http://purl.org/dc/terms/hasPart> <http://purl.org/ontology/bibo/Legislation>))
SubClassOf(<http://purl.org/ontology/bibo/Code> ObjectMinCardinality(1 <http://purl.org/dc/terms/hasPart>))

# Class: <http://purl.org/ontology/bibo/CollectedDocument> (Collected Document)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/CollectedDocument> "A document that simultaneously contains other documents."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/CollectedDocument> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/CollectedDocument> "Collected Document"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/CollectedDocument> "stable")
SubClassOf(<http://purl.org/ontology/bibo/CollectedDocument> <http://purl.org/ontology/bibo/Document>)
SubClassOf(<http://purl.org/ontology/bibo/CollectedDocument> ObjectAllValuesFrom(<http://purl.org/dc/terms/hasPart> <http://purl.org/ontology/bibo/Document>))
SubClassOf(<http://purl.org/ontology/bibo/CollectedDocument> ObjectMinCardinality(1 <http://purl.org/dc/terms/hasPart>))

# Class: <http://purl.org/ontology/bibo/Collection> (Collection)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/Collection> "A collection of Documents or Collections"@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Collection> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Collection> "Collection"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Collection> "stable")
SubClassOf(<http://purl.org/ontology/bibo/Collection> ObjectAllValuesFrom(<http://purl.org/dc/terms/hasPart> ObjectUnionOf(<http://purl.org/ontology/bibo/Collection> <http://purl.org/ontology/bibo/Document>)))

# Class: <http://purl.org/ontology/bibo/Conference> (Conference)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/Conference> "A meeting for consultation or discussion."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Conference> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Conference> "Conference"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Conference> "stable")
SubClassOf(<http://purl.org/ontology/bibo/Conference> <http://purl.org/NET/c4dm/event.owl#Event>)

# Class: <http://purl.org/ontology/bibo/CourtReporter> (Court Reporter)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/CourtReporter> "A collection of legal cases."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/CourtReporter> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/CourtReporter> "Court Reporter"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/CourtReporter> "stable")
SubClassOf(<http://purl.org/ontology/bibo/CourtReporter> <http://purl.org/ontology/bibo/Periodical>)
SubClassOf(<http://purl.org/ontology/bibo/CourtReporter> ObjectAllValuesFrom(<http://purl.org/dc/terms/hasPart> <http://purl.org/ontology/bibo/LegalDocument>))
SubClassOf(<http://purl.org/ontology/bibo/CourtReporter> ObjectMinCardinality(1 <http://purl.org/dc/terms/hasPart>))

# Class: <http://purl.org/ontology/bibo/Document> (Document)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/Document> "A document (noun) is a bounded physical representation of body of information designed with the capacity (and usually intent) to communicate. A document may manifest symbolic, diagrammatic or sensory-representational information."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Document> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Document> "Document"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Document> "stable")
EquivalentClasses(<http://purl.org/ontology/bibo/Document> <http://xmlns.com/foaf/0.1/Document>)

# Class: <http://purl.org/ontology/bibo/DocumentPart> (document part)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/DocumentPart> "a distinct part of a larger document or collected document."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/DocumentPart> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/DocumentPart> "document part"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/DocumentPart> "unstable")
SubClassOf(<http://purl.org/ontology/bibo/DocumentPart> <http://purl.org/ontology/bibo/Document>)
SubClassOf(<http://purl.org/ontology/bibo/DocumentPart> ObjectMaxCardinality(1 <http://purl.org/dc/terms/isPartOf>))

# Class: <http://purl.org/ontology/bibo/DocumentStatus> (Document Status)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/DocumentStatus> "The status of the publication of a document."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/DocumentStatus> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/DocumentStatus> "Document Status"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/DocumentStatus> "stable")

# Class: <http://purl.org/ontology/bibo/EditedBook> (Edited Book)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/EditedBook> "An edited book."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/EditedBook> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/EditedBook> "Edited Book"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/EditedBook> "stable")
SubClassOf(<http://purl.org/ontology/bibo/EditedBook> <http://purl.org/ontology/bibo/CollectedDocument>)

# Class: <http://purl.org/ontology/bibo/Excerpt> (Excerpt)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/Excerpt> "A passage selected from a larger work."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Excerpt> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Excerpt> "Excerpt"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Excerpt> "stable")
SubClassOf(<http://purl.org/ontology/bibo/Excerpt> <http://purl.org/ontology/bibo/DocumentPart>)

# Class: <http://purl.org/ontology/bibo/Film> (Film)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/Film> "aka movie."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Film> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Film> "Film"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Film> "stable")
SubClassOf(<http://purl.org/ontology/bibo/Film> <http://purl.org/ontology/bibo/AudioVisualDocument>)

# Class: <http://purl.org/ontology/bibo/Hearing> (Hearing)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/Hearing> "An instance or a session in which testimony and arguments are presented, esp. before an official, as a judge in a lawsuit."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Hearing> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Hearing> "Hearing"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Hearing> "stable")
SubClassOf(<http://purl.org/ontology/bibo/Hearing> <http://purl.org/NET/c4dm/event.owl#Event>)

# Class: <http://purl.org/ontology/bibo/Image> (Image)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/Image> "A document that presents visual or diagrammatic information."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Image> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Image> "Image"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Image> "stable")
EquivalentClasses(<http://purl.org/ontology/bibo/Image> <http://xmlns.com/foaf/0.1/Image>)
SubClassOf(<http://purl.org/ontology/bibo/Image> <http://purl.org/ontology/bibo/Document>)

# Class: <http://purl.org/ontology/bibo/Interview> (Interview)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/Interview> "A formalized discussion between two or more people."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Interview> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Interview> "Interview"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/Interview> "stable")
SubClassOf(<http://purl.org/ontology/bibo/Interview> <http://purl.org/NET/c4dm/event.owl#Event>)

# Class: <http://purl.org/ontology/bibo/Issue> (Issue)

AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/Issue> "something that is printed or published and distributed, esp. a given number of a periodical"@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/Issue> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/Issue> "Issue"@en)
