AnnotationAssertion(rdfs:comment <http://www.w3.org/2006/vcard/ns#Geo> "Used to indicate global positioning  information that is specific to an address")
AnnotationAssertion(rdfs:label <http://www.w3.org/2006/vcard/ns#Geo> "Geo"@en)
EquivalentClasses(<http://www.w3.org/2006/vcard/ns#Geo> ObjectIntersectionOf(DataSomeValuesFrom(<http://www.w3.org/2006/vcard/ns#geo> xsd:anyURI) DataMinCardinality(1 <http://www.w3.org/2006/vcard/ns#geo>)))
