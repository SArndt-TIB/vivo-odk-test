# Data Property: <http://aims.fao.org/aos/geopolitical.owl#GDP> (GDP)

AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceCreator> <http://aims.fao.org/aos/geopolitical.owl#GDP> "World Bank")
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceIdentifier> <http://aims.fao.org/aos/geopolitical.owl#GDP> "http://data.albankaldawli.org/indicator/NY.GDP.MKTP.CD"@ar)
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceIdentifier> <http://aims.fao.org/aos/geopolitical.owl#GDP> "http://data.worldbank.org/indicator/NY.GDP.MKTP.CD")
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceIdentifier> <http://aims.fao.org/aos/geopolitical.owl#GDP> "http://data.worldbank.org/indicator/NY.GDP.MKTP.CD"@en)
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceIdentifier> <http://aims.fao.org/aos/geopolitical.owl#GDP> "http://datos.bancomundial.org/indicador/NY.GDP.MKTP.CD"@es)
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceIdentifier> <http://aims.fao.org/aos/geopolitical.owl#GDP> "http://donnees.banquemondiale.org/indicateur/NY.GDP.MKTP.CD"@fr)
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceModified> <http://aims.fao.org/aos/geopolitical.owl#GDP> "2010-12-16")
AnnotationAssertion(<http://purl.org/dc/terms/description> <http://aims.fao.org/aos/geopolitical.owl#GDP> "GDP at purchaser's prices is the sum of gross value added by all resident producers in the economy plus any product taxes and minus any subsidies not included in the value of the products. It is calculated without making deductions for depreciation of fabricated assets or for depletion and degradation of natural resources. Data are in current U.S. dollars. Dollar figures for GDP are converted from domestic currencies using single year official exchange rates. For a few countries where the official exchange rate does not reflect the rate effectively applied to actual foreign exchange transactions, an alternative conversion factor is used. Source: World Bank national accounts data, and OECD National Accounts data files. http://data.worldbank.org/indicator/NY.GDP.MKTP.CD")
AnnotationAssertion(<http://purl.org/dc/terms/source> <http://aims.fao.org/aos/geopolitical.owl#GDP> "World Bank http://data.worldbank.org/indicator/NY.GDP.MKTP.CD")
AnnotationAssertion(rdfs:label <http://aims.fao.org/aos/geopolitical.owl#GDP> "GDP"@en)

# Data Property: <http://aims.fao.org/aos/geopolitical.owl#GDPNotes> (GDP notes)

AnnotationAssertion(rdfs:label <http://aims.fao.org/aos/geopolitical.owl#GDPNotes> "GDP notes"@en)

# Data Property: <http://aims.fao.org/aos/geopolitical.owl#GDPTotalInCurrentPrices> (GDP total in current prices)

AnnotationAssertion(rdfs:label <http://aims.fao.org/aos/geopolitical.owl#GDPTotalInCurrentPrices> "GDP total in current prices"@en)

# Data Property: <http://aims.fao.org/aos/geopolitical.owl#GDPUnit> (GDP unit)

AnnotationAssertion(rdfs:label <http://aims.fao.org/aos/geopolitical.owl#GDPUnit> "GDP unit"@en)

# Data Property: <http://aims.fao.org/aos/geopolitical.owl#GDPYear> (GDPYear)

AnnotationAssertion(rdfs:label <http://aims.fao.org/aos/geopolitical.owl#GDPYear> "GDPYear"@en)

# Data Property: <http://aims.fao.org/aos/geopolitical.owl#HDI> (<http://aims.fao.org/aos/geopolitical.owl#HDI>)

AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceCreator> <http://aims.fao.org/aos/geopolitical.owl#HDI> "UNDP - HDRO")
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceIdentifier> <http://aims.fao.org/aos/geopolitical.owl#HDI> "http://hdrstats.undp.org/en/indicators/49806.html")
