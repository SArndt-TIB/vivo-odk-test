#   Object Properties
############################

# Object Property: <http://aims.fao.org/aos/geopolitical.owl#hasBorderWith> (has border with)

AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceCreator> <http://aims.fao.org/aos/geopolitical.owl#hasBorderWith> "United Nations cartographic maps")
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceIdentifier> <http://aims.fao.org/aos/geopolitical.owl#hasBorderWith> "http://www.un.org/Depts/Cartographic/map/profile/world00.pdf")
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceModified> <http://aims.fao.org/aos/geopolitical.owl#hasBorderWith> "2010-05-01")
AnnotationAssertion(<http://purl.org/dc/terms/source> <http://aims.fao.org/aos/geopolitical.owl#hasBorderWith> "United Nations cartographic maps http://www.un.org/Depts/Cartographic/map/profile/world00.pdf")
AnnotationAssertion(rdfs:label <http://aims.fao.org/aos/geopolitical.owl#hasBorderWith> "has border with"@en)

# Object Property: <http://aims.fao.org/aos/geopolitical.owl#hasMember> (has member country or territory)

AnnotationAssertion(rdfs:label <http://aims.fao.org/aos/geopolitical.owl#hasMember> "has member country or territory"@en)
InverseObjectProperties(<http://aims.fao.org/aos/geopolitical.owl#hasMember> <http://aims.fao.org/aos/geopolitical.owl#isInGroup>)
ObjectPropertyDomain(<http://aims.fao.org/aos/geopolitical.owl#hasMember> <http://aims.fao.org/aos/geopolitical.owl#group>)
ObjectPropertyRange(<http://aims.fao.org/aos/geopolitical.owl#hasMember> <http://aims.fao.org/aos/geopolitical.owl#territory>)

# Object Property: <http://aims.fao.org/aos/geopolitical.owl#isAdministeredBy> (is administered by)

AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceCreator> <http://aims.fao.org/aos/geopolitical.owl#isAdministeredBy> "United Nations cartographic maps")
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceIdentifier> <http://aims.fao.org/aos/geopolitical.owl#isAdministeredBy> "http://www.un.org/Depts/Cartographic/map/profile/world00.pdf"@en)
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceModified> <http://aims.fao.org/aos/geopolitical.owl#isAdministeredBy> "2010-05-01")
AnnotationAssertion(<http://purl.org/dc/terms/source> <http://aims.fao.org/aos/geopolitical.owl#isAdministeredBy> "United Nations cartographic maps http://www.un.org/Depts/Cartographic/map/profile/world00.pdf")
AnnotationAssertion(rdfs:label <http://aims.fao.org/aos/geopolitical.owl#isAdministeredBy> "is administered by"@en)

# Object Property: <http://aims.fao.org/aos/geopolitical.owl#isInGroup> (in geographic grouping)

AnnotationAssertion(rdfs:label <http://aims.fao.org/aos/geopolitical.owl#isInGroup> "in geographic grouping"@en)
ObjectPropertyDomain(<http://aims.fao.org/aos/geopolitical.owl#isInGroup> <http://aims.fao.org/aos/geopolitical.owl#territory>)
ObjectPropertyRange(<http://aims.fao.org/aos/geopolitical.owl#isInGroup> <http://aims.fao.org/aos/geopolitical.owl#group>)

# Object Property: <http://aims.fao.org/aos/geopolitical.owl#isPredecessorOf> (is predecessor of)

AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceCreator> <http://aims.fao.org/aos/geopolitical.owl#isPredecessorOf> "United Nations Statistics Division")
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceIdentifier> <http://aims.fao.org/aos/geopolitical.owl#isPredecessorOf> "http://unstats.un.org/unsd/methods/m49/m49chang.htm"@en)
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceIdentifier> <http://aims.fao.org/aos/geopolitical.owl#isPredecessorOf> "http://unstats.un.org/unsd/methods/m49/m49chgef.htm"@fr)
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceModified> <http://aims.fao.org/aos/geopolitical.owl#isPredecessorOf> "2010-04-15")
AnnotationAssertion(<http://purl.org/dc/terms/source> <http://aims.fao.org/aos/geopolitical.owl#isPredecessorOf> "United Nations Statistics Division http://unstats.un.org/unsd/methods/m49/m49chang.htm")
AnnotationAssertion(rdfs:label <http://aims.fao.org/aos/geopolitical.owl#isPredecessorOf> "is predecessor of"@en)
InverseObjectProperties(<http://aims.fao.org/aos/geopolitical.owl#isPredecessorOf> <http://aims.fao.org/aos/geopolitical.owl#isSuccessorOf>)
ObjectPropertyDomain(<http://aims.fao.org/aos/geopolitical.owl#isPredecessorOf> <http://aims.fao.org/aos/geopolitical.owl#area>)
ObjectPropertyRange(<http://aims.fao.org/aos/geopolitical.owl#isPredecessorOf> <http://aims.fao.org/aos/geopolitical.owl#area>)

# Object Property: <http://aims.fao.org/aos/geopolitical.owl#isSuccessorOf> (is successor of)

AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceCreator> <http://aims.fao.org/aos/geopolitical.owl#isSuccessorOf> "United Nations Statistics Division")
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceIdentifier> <http://aims.fao.org/aos/geopolitical.owl#isSuccessorOf> "http://unstats.un.org/unsd/methods/m49/m49chang.htm"@en)
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceIdentifier> <http://aims.fao.org/aos/geopolitical.owl#isSuccessorOf> "http://unstats.un.org/unsd/methods/m49/m49chgef.htm"@fr)
AnnotationAssertion(<http://aims.fao.org/aos/geopolitical.owl#sourceModified> <http://aims.fao.org/aos/geopolitical.owl#isSuccessorOf> "2010-04-15")
AnnotationAssertion(<http://purl.org/dc/terms/source> <http://aims.fao.org/aos/geopolitical.owl#isSuccessorOf> "United Nations Statistics Division http://unstats.un.org/unsd/methods/m49/m49chang.htm")
AnnotationAssertion(rdfs:label <http://aims.fao.org/aos/geopolitical.owl#isSuccessorOf> "is successor of"@en)
ObjectPropertyDomain(<http://aims.fao.org/aos/geopolitical.owl#isSuccessorOf> <http://aims.fao.org/aos/geopolitical.owl#area>)
ObjectPropertyRange(<http://aims.fao.org/aos/geopolitical.owl#isSuccessorOf> <http://aims.fao.org/aos/geopolitical.owl#area>)


