############################
#   Annotation Properties
############################

# Annotation Property: <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> (term status)

AnnotationAssertion(rdfs:comment <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "the status of a vocabulary term, expressed as a short symbolic string; known values include 'unstable','testing', 'stable' and 'archaic'")
AnnotationAssertion(rdfs:isDefinedBy <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://www.w3.org/2003/06/sw-vocab-status/ns#>)
AnnotationAssertion(rdfs:label <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "term status")
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "unstable")



