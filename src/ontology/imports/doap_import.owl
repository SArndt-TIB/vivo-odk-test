############################
#   Object Properties
############################

# Object Property: <http://xmlns.com/foaf/0.1/made> (made)

AnnotationAssertion(rdfs:label <http://xmlns.com/foaf/0.1/made> "made")
InverseObjectProperties(<http://xmlns.com/foaf/0.1/made> <http://xmlns.com/foaf/0.1/maker>)
ObjectPropertyDomain(<http://xmlns.com/foaf/0.1/made> <http://xmlns.com/foaf/0.1/Agent>)

# Object Property: <http://xmlns.com/foaf/0.1/maker> (maker)

AnnotationAssertion(rdfs:label <http://xmlns.com/foaf/0.1/maker> "maker")
ObjectPropertyRange(<http://xmlns.com/foaf/0.1/maker> <http://xmlns.com/foaf/0.1/Agent>)

# Object Property: <http://xmlns.com/foaf/0.1/mbox> (personal mailbox)

AnnotationAssertion(rdfs:label <http://xmlns.com/foaf/0.1/mbox> "personal mailbox")
InverseFunctionalObjectProperty(<http://xmlns.com/foaf/0.1/mbox>)
ObjectPropertyDomain(<http://xmlns.com/foaf/0.1/mbox> <http://xmlns.com/foaf/0.1/Agent>)


############################
#   Data Properties
############################

# Data Property: <http://xmlns.com/foaf/0.1/name> (name)

AnnotationAssertion(rdfs:label <http://xmlns.com/foaf/0.1/name> "name")



############################
#   Classes
############################

# Class: <http://purl.org/dc/terms/Agent> (<http://purl.org/dc/terms/Agent>)

EquivalentClasses(<http://purl.org/dc/terms/Agent> <http://xmlns.com/foaf/0.1/Agent>)

# Class: <http://schema.org/Person> (<http://schema.org/Person>)

EquivalentClasses(<http://schema.org/Person> <http://xmlns.com/foaf/0.1/Person>)

# Class: <http://www.w3.org/2000/10/swap/pim/contact#Person> (<http://www.w3.org/2000/10/swap/pim/contact#Person>)

EquivalentClasses(<http://www.w3.org/2000/10/swap/pim/contact#Person> <http://xmlns.com/foaf/0.1/Person>)

# Class: <http://www.w3.org/2003/01/geo/wgs84_pos#SpatialThing> (Spatial Thing)

AnnotationAssertion(rdfs:label <http://www.w3.org/2003/01/geo/wgs84_pos#SpatialThing> "Spatial Thing")

# Class: <http://xmlns.com/foaf/0.1/Agent> (Agent)

AnnotationAssertion(rdfs:label <http://xmlns.com/foaf/0.1/Agent> "Agent")

# Class: <http://xmlns.com/foaf/0.1/Person> (Person)

AnnotationAssertion(rdfs:label <http://xmlns.com/foaf/0.1/Person> "Person")
SubClassOf(<http://xmlns.com/foaf/0.1/Person> <http://www.w3.org/2003/01/geo/wgs84_pos#SpatialThing>)
SubClassOf(<http://xmlns.com/foaf/0.1/Person> <http://xmlns.com/foaf/0.1/Agent>)


