Ontology(<http://purl.obolibrary.org/obo//imports/doap_import.owl>
<http://purl.obolibrary.org/obo//releases/2026-03-23/imports/doap_import.owl>
Annotation(owl:versionInfo "2026-03-23")

Declaration(Class(<http://purl.org/dc/terms/Agent>))
Declaration(Class(<http://schema.org/Person>))
Declaration(Class(<http://www.w3.org/2000/10/swap/pim/contact#Person>))
Declaration(Class(<http://www.w3.org/2003/01/geo/wgs84_pos#SpatialThing>))
Declaration(Class(<http://xmlns.com/foaf/0.1/Agent>))
Declaration(Class(<http://xmlns.com/foaf/0.1/Person>))
Declaration(ObjectProperty(<http://xmlns.com/foaf/0.1/made>))
Declaration(ObjectProperty(<http://xmlns.com/foaf/0.1/maker>))
Declaration(ObjectProperty(<http://xmlns.com/foaf/0.1/mbox>))
Declaration(DataProperty(<http://xmlns.com/foaf/0.1/name>))
Declaration(NamedIndividual(<http://usefulinc.com/ns/doap#>))
