SubClassOf(<http://purl.org/ontology/bibo/Periodical> ObjectAllValuesFrom(:publisher <http://xmlns.com/foaf/0.1/Organization>))
SubClassOf(<http://purl.org/ontology/bibo/Periodical> DataAllValuesFrom(<http://purl.org/ontology/bibo/eissn> rdfs:Literal))
SubClassOf(<http://purl.org/ontology/bibo/Periodical> DataAllValuesFrom(<http://purl.org/ontology/bibo/issn> rdfs:Literal))

