AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/DocumentStatus> "The status of the publication of a document."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/DocumentStatus> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.org/ontology/bibo/DocumentStatus> "Document Status"@en)
AnnotationAssertion(<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> <http://purl.org/ontology/bibo/DocumentStatus> "stable")

