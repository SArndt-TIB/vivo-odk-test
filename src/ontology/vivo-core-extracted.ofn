# Data Property: :wikidataId (Wikidata ID)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000111> :wikidataId "Wikidata ID"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000112> :wikidataId "Identifiers can be used as standalone in human-readable text: for instance, Q28136655 = \"VIVO\". They can be combined with the proper URI prefix to get the corresponding Wikidata URI, which always resolves to an URL: for instance, https://www.wikidata.org/wiki/Q28136655 . The URIs can be shortened using a namespace prefix: for instance, wd:Q28136655; this is the preferred writing for expressing statements in Turtle triples, in SPARQL queries, etc.")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> :wikidataId "Identifier for an entity on Wikidata")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> :wikidataId "Wikidata entity ID"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> :wikidataId "Wikidata identifier"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :wikidataId <https://www.wikidata.org/wiki/Q111513370>)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :wikidataId <https://www.wikidata.org/wiki/Wikidata:Identifiers>)
AnnotationAssertion(<http://vitro.mannlib.cornell.edu/ns/vitro/0.7#exampleAnnot> :wikidataId "Identifiers can be used as standalone in human-readable text: for instance, Q28136655 = \"VIVO\". They can be combined with the proper URI prefix to get the corresponding Wikidata URI, which always resolves to an URL: for instance, https://www.wikidata.org/wiki/Q28136655 . The URIs can be shortened using a namespace prefix: for instance, wd:Q28136655; this is the preferred writing for expressing statements in Turtle triples, in SPARQL queries, etc.")
AnnotationAssertion(rdfs:comment :wikidataId "A Wikidata ID is a unique identifier assigned by Wikidata to an entity. It is an alphanumeric string (e.g., Q28136655) that serves to identify the entity in the Wikidata database (https://www.wikidata.org/) and query for it. In particular, an IDs for a class has the form Q\\d*, one for a property has the form P\\d*, where \\d* is a sequence of digits of any length."@en)
AnnotationAssertion(rdfs:isDefinedBy :wikidataId <http://vivoweb.org/ontology/core>)
AnnotationAssertion(rdfs:label :wikidataId "Wikidata ID"@en)
SubDataPropertyOf(:wikidataId :identifier)

# Data Property: <http://vivoweb.org/ontology/scientific-research#irbNumber> (Institutional Review Board (IRB) number)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://vivoweb.org/ontology/scientific-research#irbNumber> "Every clinical trial in the United States must be approved and monitored by an Institutional Review Board (IRB). An IRB is an independent committee of physicians, statisticians, community advocates and others whose objective is to ensure that a clinical trial is ethical and the rights of study participants are protected. ")
AnnotationAssertion(rdfs:label <http://vivoweb.org/ontology/scientific-research#irbNumber> "Institutional Review Board (IRB) number"@en)

# Data Property: <http://vivoweb.org/ontology/scientific-research#nctId> (National Clinical Trials (NCT) number)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://vivoweb.org/ontology/scientific-research#nctId> "ClinicalTrials.gov is an ICMJE-acceptable public registry, offering up-to-date information for locating clinical trials for a wide range of diseases and conditions. The U.S. National Institutes of Health (NIH), through its National Library of Medicine (NLM), developed this site in collaboration with the Food and Drug Administration (FDA), as a result of the FDA Modernization Act, which was passed into law in November 1997.   This property should be publically visible since it is one of the principal identifiers in a national registry of clinical trials ")
AnnotationAssertion(<http://vitro.mannlib.cornell.edu/ns/vitro/0.7#exampleAnnot> <http://vivoweb.org/ontology/scientific-research#nctId> "NCT00000419")
AnnotationAssertion(rdfs:label <http://vivoweb.org/ontology/scientific-research#nctId> "National Clinical Trials (NCT) number"@en)

# Data Property: <http://vivoweb.org/ontology/scientific-research#studyPopulationCount> (study population count)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://vivoweb.org/ontology/scientific-research#studyPopulationCount> "number of human participants in the study (trial).")
AnnotationAssertion(rdfs:label <http://vivoweb.org/ontology/scientific-research#studyPopulationCount> "study population count"@en)

