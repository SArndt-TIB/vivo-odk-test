AnnotationAssertion(rdfs:comment <http://purl.org/ontology/bibo/LegalDocument> "A legal document; for example, a court decision, a brief, and so forth."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.org/ontology/bibo/LegalDocument> "http://purl.org/ontology/bibo/"^^xsd:anyURI)
