# Class: <http://xmlns.com/foaf/0.1/Agent> (Agent)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000111> <http://xmlns.com/foaf/0.1/Agent> "agent")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000112> <http://xmlns.com/foaf/0.1/Agent> "see: http://xmlns.com/foaf/spec/#term_Agent")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://xmlns.com/foaf/0.1/Agent> "Agents are things that do stuff")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://xmlns.com/foaf/0.1/Agent> "Things that do stuff.")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://xmlns.com/foaf/0.1/Agent> "PERSON: Scott Hoffmann")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> <http://xmlns.com/foaf/0.1/Agent> "")
AnnotationAssertion(rdfs:comment <http://xmlns.com/foaf/0.1/Agent> "An agent")
AnnotationAssertion(rdfs:label <http://xmlns.com/foaf/0.1/Agent> "Agent"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#scopeNote> <http://xmlns.com/foaf/0.1/Agent> "Used to describe any \"agent\" related to bibliographic items. Such agents can be persons, organizations or groups of any kind."@en)
SubClassOf(<http://xmlns.com/foaf/0.1/Agent> <http://purl.obolibrary.org/obo/BFO_0000004>)
SubClassOf(<http://xmlns.com/foaf/0.1/Agent> ObjectAllValuesFrom(:featuredIn <http://purl.obolibrary.org/obo/IAO_0000030>))
SubClassOf(<http://xmlns.com/foaf/0.1/Agent> ObjectAllValuesFrom(:relatedBy :Relationship))
SubClassOf(<http://xmlns.com/foaf/0.1/Agent> DataAllValuesFrom(:freetextKeyword rdfs:Literal))

# Class: <http://xmlns.com/foaf/0.1/Group> (Group)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000111> <http://xmlns.com/foaf/0.1/Group> "group")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000112> <http://xmlns.com/foaf/0.1/Group> "A group can also be an organization but need not be; typically used for looser associations of people or organizations acting together in some fashion, not necessarily through formal agreement or on a long-term basis. Added to the VIVO ontology to be able to support informal and perhaps even private groups of people around an idea, funding opportunity, or event.

see: http://xmlns.com/foaf/spec/#term_Group")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://xmlns.com/foaf/0.1/Group> " A collection of individual agents (and may itself play the role of a Agent, ie. something that can perform actions). ")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://xmlns.com/foaf/0.1/Group> "A collection of individual agents.")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://xmlns.com/foaf/0.1/Group> "PERSON: Scott Hoffmann")
AnnotationAssertion(rdfs:comment <http://xmlns.com/foaf/0.1/Group> "A group")
AnnotationAssertion(rdfs:label <http://xmlns.com/foaf/0.1/Group> "Group"@en)
SubClassOf(<http://xmlns.com/foaf/0.1/Group> <http://xmlns.com/foaf/0.1/Agent>)

# Class: <http://xmlns.com/foaf/0.1/Organization> (Organization)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000111> <http://xmlns.com/foaf/0.1/Organization> "organization")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000112> <http://xmlns.com/foaf/0.1/Organization> "Only use if no specific subclasses of foaf:organization desribe the organization.")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000112> <http://xmlns.com/foaf/0.1/Organization> "This class will display all the instances in the subclasses below it, as well as any organizations that were added as part of this generic class because there wasn't a specific class available.")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://xmlns.com/foaf/0.1/Organization> "A generic class encompassing several types of organizations.")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://xmlns.com/foaf/0.1/Organization> "A kind of Agent corresponding to social instititutions such as companies, societies etc.")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://xmlns.com/foaf/0.1/Organization> "PERSON: Scott Hoffmann")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> <http://xmlns.com/foaf/0.1/Organization> "")
AnnotationAssertion(rdfs:comment <http://xmlns.com/foaf/0.1/Organization> "An organization")
AnnotationAssertion(rdfs:label <http://xmlns.com/foaf/0.1/Organization> "Organization"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#scopeNote> <http://xmlns.com/foaf/0.1/Organization> "Ued to describe an organization related to bibliographic items such as a publishing company, etc."@en)
SubClassOf(<http://xmlns.com/foaf/0.1/Organization> <http://xmlns.com/foaf/0.1/Agent>)
SubClassOf(<http://xmlns.com/foaf/0.1/Organization> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/ARG_2000028> <http://www.w3.org/2006/vcard/ns#Organization>))
SubClassOf(<http://xmlns.com/foaf/0.1/Organization> ObjectAllValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000051> <http://xmlns.com/foaf/0.1/Organization>))
SubClassOf(<http://xmlns.com/foaf/0.1/Organization> ObjectAllValuesFrom(<http://purl.obolibrary.org/obo/RO_0001025> :GeographicLocation))
SubClassOf(<http://xmlns.com/foaf/0.1/Organization> ObjectAllValuesFrom(:dateTimeInterval :DateTimeInterval))
SubClassOf(<http://xmlns.com/foaf/0.1/Organization> DataAllValuesFrom(:abbreviation rdfs:Literal))

# Class: <http://xmlns.com/foaf/0.1/Person> (Person)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000111> <http://xmlns.com/foaf/0.1/Person> "person")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://xmlns.com/foaf/0.1/Person> "An instance of a human being (Homo sapiens)")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://xmlns.com/foaf/0.1/Person> "The most general classification of a person")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://xmlns.com/foaf/0.1/Person> "PERSON: Melissa Haendel")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> <http://xmlns.com/foaf/0.1/Person> "")
AnnotationAssertion(rdfs:comment <http://xmlns.com/foaf/0.1/Person> "A person")
AnnotationAssertion(rdfs:label <http://xmlns.com/foaf/0.1/Person> "Person"@en)
SubClassOf(<http://xmlns.com/foaf/0.1/Person> <http://xmlns.com/foaf/0.1/Agent>)
SubClassOf(<http://xmlns.com/foaf/0.1/Person> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/ARG_2000028> <http://www.w3.org/2006/vcard/ns#Individual>))
SubClassOf(<http://xmlns.com/foaf/0.1/Person> ObjectAllValuesFrom(:eligibleFor :Credential))
SubClassOf(<http://xmlns.com/foaf/0.1/Person> ObjectAllValuesFrom(:geographicFocus :GeographicRegion))
SubClassOf(<http://xmlns.com/foaf/0.1/Person> ObjectAllValuesFrom(:hasResearchArea owl:Thing))
SubClassOf(<http://xmlns.com/foaf/0.1/Person> DataAllValuesFrom(:freetextKeyword xsd:string))


