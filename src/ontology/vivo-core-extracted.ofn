# Class: :AcademicDegree (Academic Degree)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000112> :AcademicDegree "B.A. Bachelor of Arts"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000114> :AcademicDegree <http://purl.obolibrary.org/obo/IAO_0000120>)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> :AcademicDegree "An academic degree at any level, both as 
        reported by individuals for employment and as offered by academic degree programs."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000116> :AcademicDegree "The ObjectProperty relates is used to associate an AcademicDegree with an AwardedDegree.  A preferred
        approach would be to recognize the AwardedDegree as an information artifact which is the output of an AcademicDegree process.
        This would eliminate the use of relates and relatedBy in the
        representation of Academic Degrees and Awarded Degrees, provide correct subsumption, and avoid the use of vivo:Relationship. Further, we could
        rename AwardedDegree AcademicDegree (!) and rename AcademicDegree to AcademicDegreeProcess and eliminate the need for
        the EducationalProcess currently in the model.
        "@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> :AcademicDegree "PERSON: Michael Conlon"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :AcademicDegree "Merriam Webster (https://www.merriam-webster.com/dictionary/degree)"@en)
AnnotationAssertion(rdfs:label :AcademicDegree "Academic Degree"@en)
SubClassOf(:AcademicDegree DataAllValuesFrom(:abbreviation rdfs:Literal))
SubClassOf(:AcademicDegree DataMinCardinality(1 :abbreviation xsd:nonNegativeInteger))

