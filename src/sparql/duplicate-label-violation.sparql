PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

# Only check for duplicate labels among terms defined in the vivotest
# edit file itself. Without the GRAPH filter, label collisions that
# originate entirely within imported ontologies would be reported even
# though we cannot fix them here.

SELECT ?label (COUNT(?entity) AS ?count) (GROUP_CONCAT(?entity; separator=", ") AS ?entities)
WHERE {
  GRAPH <http://purl.obolibrary.org/obo/vivotest.owl> {
    ?entity rdfs:label ?label .
  }
  FILTER(isIRI(?entity))
}
GROUP BY ?label
HAVING (COUNT(?entity) > 1)
ORDER BY ?label
